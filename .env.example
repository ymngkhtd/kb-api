# Knowledge Base Root (defaults to parent of kb-api directory)
# KB_ROOT=D:/knowledgeLib

# JWT Configuration (MUST change secret before use!)
KB_JWT_SECRET=please-change-this-secret-key
KB_JWT_ALGORITHM=HS256
KB_JWT_ACCESS_EXPIRE_MINUTES=60
KB_JWT_REFRESH_EXPIRE_DAYS=7

# Server (default: localhost only)
KB_HOST=127.0.0.1
KB_PORT=8000

# Embedding Provider: "local" or "openai"
KB_EMBEDDING_PROVIDER=local
# Local model (sentence-transformers, supports any HuggingFace model)
KB_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# OpenAI compatible API (optional, only when KB_EMBEDDING_PROVIDER=openai)
KB_OPENAI_API_KEY=
KB_OPENAI_BASE_URL=

# Git auto-commit on write operations (requires git in PATH)
KB_GIT_AUTO_COMMIT=false

# Logging level: DEBUG, INFO, WARNING, ERROR
KB_LOG_LEVEL=INFO
